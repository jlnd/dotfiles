# ~/.wgetrc — default wget options.

# Use the server-provided last-modified date when saving files.
timestamping = on

# When recursing, don't ascend into the parent directory.
no_parent = on

# 60s timeout (the default read timeout is 15 minutes).
timeout = 60

# Retry a few times on failure (the default is 20 — overkill).
tries = 3

# Retry even when the connection is refused.
retry_connrefused = on

# Use the last component of a redirect URL as the local filename.
trust_server_names = on

# Follow FTP links from HTML documents.
follow_ftp = on

# Add a `.html` / `.css` extension to files served as text/html / text/css
# when they don't already have one.
adjust_extension = on

# Ignore robots.txt (so wget can mirror your own sites).
robots = off

# Print HTTP/FTP server responses.
server_response = on
