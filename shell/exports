# ~/.exports — environment variables
# Sourced from ~/.zshrc

# Default editor (works in commit messages, crontab, etc.)
export EDITOR="code --wait"
export VISUAL="$EDITOR"

# Pager
export PAGER="less"
export LESS="-R --mouse --wheel-lines=3"

# UTF-8 everywhere
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Highlight man pages with bat (if installed)
if command -v bat >/dev/null 2>&1; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# Use GNU coreutils (installed via Homebrew) without the `g` prefix
if [[ -d "$(brew --prefix coreutils 2>/dev/null)/libexec/gnubin" ]]; then
  export PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"
  export MANPATH="$(brew --prefix coreutils)/libexec/gnuman:$MANPATH"
fi

# Add ~/bin and ~/.local/bin to PATH if they exist
[[ -d "$HOME/bin" ]] && export PATH="$HOME/bin:$PATH"
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"
